# Server
PORT=3000
HOST=0.0.0.0

# Network: "base-mainnet" | "base-sepolia"
PRMISSION_NETWORK=base-mainnet

# Optional: override RPC (defaults match the network above)
PRMISSION_RPC_URL=https://mainnet.base.org

# Optional: override contract address (default is Base mainnet)
PRMISSION_CONTRACT_ADDRESS=0x0c8B16a57524f4009581B748356E01e1a969223d

# Write tools (OPTIONAL)
# If set, enables on-chain write tools using this wallet as the agent signer.
# WARNING: Keep balances low. Never share this key.
AGENT_PRIVATE_KEY=

# Auth token (OPTIONAL but strongly recommended for remote deployments)
# If set, all /mcp requests must include: Authorization: Bearer <token>
MCP_AUTH_TOKEN=
